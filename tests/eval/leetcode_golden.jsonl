# LeetCode SQL Golden Set — 50题测试集
# 来源: LeetCode高频SQL50题（基础版）
# 数据库: data/leetcode_test.db (SQLite)
# 所有SQL已从MySQL转换为SQLite兼容语法

{"id": "lc-1757", "leetcode_id": "1757", "query": "找出既是低脂又是可回收的产品编号", "difficulty": "easy", "tables": ["Products"], "mysql_sql": "select product_id from Products where low_fats = 'Y' and recyclable = 'Y';", "expected_sql": "SELECT product_id FROM Products WHERE low_fats = 'Y' AND recyclable = 'Y';", "expected_result_summary": "LeetCode 1757: 可回收且低脂的产品", "tags": ["easy", "leetcode"]}
{"id": "lc-584", "leetcode_id": "584", "query": "找出没有被 id=2 的客户推荐的客户的姓名", "difficulty": "easy", "tables": ["Customer"], "mysql_sql": "select name from Customer where referee_id != 2 or referee_id is null;", "expected_sql": "SELECT name FROM Customer WHERE referee_id != 2 OR referee_id IS NULL;", "expected_result_summary": "LeetCode 584: 寻找用户推荐人", "tags": ["easy", "leetcode"]}
{"id": "lc-595", "leetcode_id": "595", "query": "找出面积至少300万平方公里或人口至少2500万的大国的名称、人口和面积", "difficulty": "easy", "tables": ["World"], "mysql_sql": "select name,population,area from World where area >= 3000000 or population >=25000000;", "expected_sql": "SELECT name, population, area FROM World WHERE area >= 3000000 OR population >= 25000000;", "expected_result_summary": "LeetCode 595: 大的国家", "tags": ["easy", "leetcode"]}
{"id": "lc-1148", "leetcode_id": "1148", "query": "查询出所有浏览过自己文章的作者，结果按id升序排列", "difficulty": "easy", "tables": ["Views"], "mysql_sql": "select distinct t1.author_id as id from Views as t1 where t1.author_id = t1.viewer_id order by id;", "expected_sql": "SELECT DISTINCT author_id AS id FROM Views WHERE author_id = viewer_id ORDER BY id;", "expected_result_summary": "LeetCode 1148: 文章浏览I", "tags": ["easy", "leetcode"]}
{"id": "lc-1683", "leetcode_id": "1683", "query": "查询所有无效推文的编号，当推文内容字符数严格大于15时该推文无效", "difficulty": "easy", "tables": ["Tweets"], "mysql_sql": "select tweet_id from Tweets where char_length(content) > 15;", "expected_sql": "SELECT tweet_id FROM Tweets WHERE LENGTH(content) > 15;", "expected_result_summary": "LeetCode 1683: 无效的推文", "tags": ["easy", "leetcode"]}
{"id": "lc-1378", "leetcode_id": "1378", "query": "展示每位员工的唯一标识码，如果某位员工没有唯一标识码则使用null填充", "difficulty": "easy", "tables": ["Employees", "EmployeeUNI"], "mysql_sql": "select t2.unique_id,t1.name from Employees as t1 left join EmployeeUNI as t2 on t1.id = t2.id;", "expected_sql": "SELECT t2.unique_id, t1.name FROM Employees AS t1 LEFT JOIN EmployeeUNI AS t2 ON t1.id = t2.id;", "expected_result_summary": "LeetCode 1378: 使用唯一标识码替换员工ID", "tags": ["easy", "leetcode"]}
{"id": "lc-1068", "leetcode_id": "1068", "query": "获取Sales表中所有sale_id对应的product_name以及该产品的所有year和price", "difficulty": "easy", "tables": ["Sales", "Product"], "mysql_sql": "select t1.year,t1.price,t2.product_name from Sales as t1 left join Product as t2 on t1.product_id = t2.product_id;", "expected_sql": "SELECT t2.product_name, t1.year, t1.price FROM Sales AS t1 LEFT JOIN Product AS t2 ON t1.product_id = t2.product_id;", "expected_result_summary": "LeetCode 1068: 产品销售分析I", "tags": ["easy", "leetcode"]}
{"id": "lc-1581", "leetcode_id": "1581", "query": "查找进店却未进行过交易的顾客ID以及他们只光顾不交易的次数", "difficulty": "easy", "tables": ["Visits", "Transactions"], "mysql_sql": "select customer_id, count(visit_id) as count_no_trans from Visits where visit_id not in(select distinct visit_id from Transactions) group by customer_id;", "expected_sql": "SELECT customer_id, COUNT(visit_id) AS count_no_trans FROM Visits WHERE visit_id NOT IN (SELECT DISTINCT visit_id FROM Transactions) GROUP BY customer_id;", "expected_result_summary": "LeetCode 1581: 进店却未进行过交易的顾客", "tags": ["easy", "leetcode"]}
{"id": "lc-197", "leetcode_id": "197", "query": "找出与之前日期相比温度更高的所有日期的id", "difficulty": "easy", "tables": ["Weather"], "mysql_sql": "select a.id from Weather as a, Weather as b where datediff(a.recordDate,b.recordDate) = 1 and a.Temperature > b.Temperature;", "expected_sql": "SELECT a.id FROM Weather AS a JOIN Weather AS b ON julianday(a.recordDate) - julianday(b.recordDate) = 1 AND a.temperature > b.temperature;", "expected_result_summary": "LeetCode 197: 上升的温度", "tags": ["easy", "leetcode"]}
{"id": "lc-1661", "leetcode_id": "1661", "query": "计算每台机器完成一个进程任务的平均耗时，四舍五入保留3位小数", "difficulty": "easy", "tables": ["Activity"], "mysql_sql": "select a.machine_id, round(avg(b.timestamp - a.timestamp),3) as processing_time from (select * from Activity where activity_type = 'start') as a left join (select * from Activity where activity_type = 'end') as b on a.machine_id = b.machine_id and a.process_id = b.process_id group by machine_id;", "expected_sql": "SELECT a.machine_id, ROUND(AVG(b.timestamp - a.timestamp), 3) AS processing_time FROM (SELECT * FROM Activity WHERE activity_type = 'start') AS a LEFT JOIN (SELECT * FROM Activity WHERE activity_type = 'end') AS b ON a.machine_id = b.machine_id AND a.process_id = b.process_id GROUP BY machine_id;", "expected_result_summary": "LeetCode 1661: 每台机器进程的平均运行时间", "tags": ["easy", "leetcode"]}
{"id": "lc-577", "leetcode_id": "577", "query": "报告每个奖金少于1000的员工的姓名和奖金数额", "difficulty": "easy", "tables": ["Employee_577", "Bonus"], "mysql_sql": "select t1.name,t2.bonus from Employee as t1 left join Bonus as t2 on t1.empId = t2.empId where t2.bonus is null or t2.bonus <1000;", "expected_sql": "SELECT t1.name, t2.bonus FROM Employee_577 AS t1 LEFT JOIN Bonus AS t2 ON t1.empId = t2.empId WHERE t2.bonus IS NULL OR t2.bonus < 1000;", "expected_result_summary": "LeetCode 577: 员工奖金", "tags": ["easy", "leetcode"]}
{"id": "lc-1280", "leetcode_id": "1280", "query": "查询每个学生参加每一门科目测试的次数，结果按student_id和subject_name排序", "difficulty": "easy", "tables": ["Students", "Subjects", "Examinations"], "mysql_sql": "select t1.student_id, t1.student_name, t2.subject_name, count(t3.subject_name) as attended_exams from Students as t1 join Subjects as t2 left join Examinations as t3 on t1.student_id = t3.student_id and t2.subject_name = t3.subject_name group by t1.student_id, t2.subject_name order by t1.student_id, t2.subject_name;", "expected_sql": "SELECT t1.student_id, t1.student_name, t2.subject_name, COUNT(t3.subject_name) AS attended_exams FROM Students AS t1 JOIN Subjects AS t2 LEFT JOIN Examinations AS t3 ON t1.student_id = t3.student_id AND t2.subject_name = t3.subject_name GROUP BY t1.student_id, t2.subject_name ORDER BY t1.student_id, t2.subject_name;", "expected_result_summary": "LeetCode 1280: 学生们参加各科测试的次数", "tags": ["easy", "leetcode"]}
{"id": "lc-620", "leetcode_id": "620", "query": "找出所有影片描述为非boring的并且id为奇数的影片，按rating降序排列", "difficulty": "easy", "tables": ["cinema"], "mysql_sql": "select * from cinema where description != 'boring' and id%2!=0 order by rating desc;", "expected_sql": "SELECT * FROM cinema WHERE description != 'boring' AND id % 2 != 0 ORDER BY rating DESC;", "expected_result_summary": "LeetCode 620: 有趣的电影", "tags": ["easy", "leetcode"]}
{"id": "lc-1251", "leetcode_id": "1251", "query": "查找每种产品的平均售价，四舍五入到小数点后两位，如果没有售出则平均售价为0", "difficulty": "easy", "tables": ["Prices", "UnitsSold"], "mysql_sql": "SELECT a.product_id, ROUND(SUM(a.t_price)/SUM(a.units),2) AS average_price FROM (SELECT p.product_id, p.price*u.units AS t_price, u.units AS units FROM Prices p JOIN UnitsSold u ON u.product_id=p.product_id WHERE u.purchase_date BETWEEN p.start_date AND p.end_date) AS a GROUP BY a.product_id;", "expected_sql": "SELECT a.product_id, ROUND(SUM(a.t_price) / SUM(a.units), 2) AS average_price FROM (SELECT p.product_id, p.price * u.units AS t_price, u.units AS units FROM Prices p JOIN UnitsSold u ON u.product_id = p.product_id WHERE u.purchase_date BETWEEN p.start_date AND p.end_date) AS a GROUP BY a.product_id;", "expected_result_summary": "LeetCode 1251: 平均售价", "tags": ["easy", "leetcode"]}
{"id": "lc-1075", "leetcode_id": "1075", "query": "查询每一个项目中员工的平均工作年限，精确到小数点后两位", "difficulty": "easy", "tables": ["Project", "Employee_1075"], "mysql_sql": "select t1.project_id, round(avg(t2.experience_years),2) as average_years from Project as t1 join Employee as t2 on t1.employee_id = t2.employee_id group by project_id;", "expected_sql": "SELECT t1.project_id, ROUND(AVG(t2.experience_years), 2) AS average_years FROM Project AS t1 JOIN Employee_1075 AS t2 ON t1.employee_id = t2.employee_id GROUP BY project_id;", "expected_result_summary": "LeetCode 1075: 项目员工I", "tags": ["easy", "leetcode"]}
{"id": "lc-1633", "leetcode_id": "1633", "query": "统计各赛事的用户注册百分率，保留两位小数，按percentage降序排序", "difficulty": "easy", "tables": ["Users", "Register"], "mysql_sql": "select contest_id, round(count(user_id)*100 / (select count(*) from Users),2) as percentage from Register group by contest_id order by percentage desc, contest_id;", "expected_sql": "SELECT contest_id, ROUND(COUNT(user_id) * 100.0 / (SELECT COUNT(*) FROM Users), 2) AS percentage FROM Register GROUP BY contest_id ORDER BY percentage DESC, contest_id;", "expected_result_summary": "LeetCode 1633: 各赛事的用户注册率", "tags": ["easy", "leetcode"]}
{"id": "lc-1211", "leetcode_id": "1211", "query": "找出每次query_name的quality（评分与位置比率的平均值）和poor_query_percentage（评分小于3的查询占比），都四舍五入到两位小数", "difficulty": "easy", "tables": ["Queries"], "mysql_sql": "SELECT query_name, ROUND(AVG(rating/position), 2) quality, ROUND(SUM(IF(rating < 3, 1, 0)) * 100 / COUNT(*), 2) poor_query_percentage FROM Queries Where query_name IS NOT NULL GROUP BY query_name;", "expected_sql": "SELECT query_name, ROUND(AVG(CAST(rating AS REAL) / position), 2) AS quality, ROUND(SUM(CASE WHEN rating < 3 THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 2) AS poor_query_percentage FROM Queries WHERE query_name IS NOT NULL GROUP BY query_name;", "expected_result_summary": "LeetCode 1211: 查询结果的质量和占比", "tags": ["easy", "leetcode"]}
{"id": "lc-570", "leetcode_id": "570", "query": "找出至少有五个直接下属的经理", "difficulty": "medium", "tables": ["Employee_570"], "mysql_sql": "select name from Employee where id in (select managerId from Employee group by managerId having count(*)>=5);", "expected_sql": "SELECT name FROM Employee_570 WHERE id IN (SELECT managerId FROM Employee_570 GROUP BY managerId HAVING COUNT(*) >= 5);", "expected_result_summary": "LeetCode 570: 至少有5名直接下属的经理", "tags": ["medium", "leetcode"]}
{"id": "lc-1934", "leetcode_id": "1934", "query": "查找每个用户的确认率（confirmed消息数除以总请求数），四舍五入到两位小数，没有请求的用户确认率为0", "difficulty": "medium", "tables": ["Signups", "Confirmations"], "mysql_sql": "select T1.user_id, round(count(if(T2.action = 'confirmed',true,null)) / count(*),2) as confirmation_rate from Signups as T1 left join Confirmations as T2 on T1.user_id = T2.user_id group by T1.user_id;", "expected_sql": "SELECT T1.user_id, ROUND(COUNT(CASE WHEN T2.action = 'confirmed' THEN 1 ELSE NULL END) * 1.0 / COUNT(T2.user_id), 2) AS confirmation_rate FROM Signups AS T1 LEFT JOIN Confirmations AS T2 ON T1.user_id = T2.user_id GROUP BY T1.user_id;", "expected_result_summary": "LeetCode 1934: 确认率", "tags": ["medium", "leetcode"]}
