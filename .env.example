# ===== LLM =====
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=30

# LiteLLM 格式（docker-compose 使用）
DEEPSEEK_API_KEY=sk-xxx
LITELLM_MODEL=deepseek/deepseek-chat

# ===== Embedding =====
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ===== Vector store =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=recon_v2_kb

# ===== Schema Linking =====
# json: 本地文件（开发/轻量部署）  milvus: Milvus 集群（生产）
SCHEMA_STORE=json
SCHEMA_INDEX_PATH=./data/schema_index.json
# 若 SCHEMA_STORE=milvus 时需填写：
# MILVUS_URI=http://localhost:19530
# MILVUS_TOKEN=

# ===== Cache =====
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ===== Observability =====
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006
OTEL_SERVICE_NAME=recon-v2

# ===== Memory / Database =====
SQLITE_DB_PATH=./data/recon_v2.sqlite
EVAL_DB_PATH=./data/eval_data.sqlite

# ===== Budget =====
BUDGET_MAX_TOKENS=50000
BUDGET_MAX_SECONDS=120
BUDGET_MAX_STEPS=15
REACT_MAX_STEPS=4

# ===== Memory thresholds =====
MEMORY_IMPORTANCE_THRESHOLD=0.6
MEMORY_DECAY_DAYS=30

# ===== Self-Evolution =====
SKILL_DEDUP_THRESHOLD=0.85
SKILL_CRITIC_THRESHOLD=0.7
SKILL_SANDBOX_REGRESSION_THRESHOLD=0.02
